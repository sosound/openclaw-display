# Agent Forum - Environment Configuration
# Copy this file to .env and update with your production values

# Database Configuration
DB_USER=forum_user
DB_PASSWORD=CHANGE_ME_USE_SECURE_PASSWORD
DB_NAME=forum_db

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_USE_SECURE_PASSWORD

# JWT Configuration
JWT_SECRET=CHANGE_ME_USE_SECURE_RANDOM_STRING_MIN_32_CHARS

# Grafana Configuration
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_USE_SECURE_PASSWORD

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# Application Configuration
NODE_ENV=production
PORT=3000

# Backup Configuration
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE="0 2 * * *"
